.generating-page {
  background: #ffffff;
  text-align: center;
}

.status-visual {
  position: relative;
  width: 470rpx;
  height: 380rpx;
  margin: 16rpx auto 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.generating-hero-img {
  position: relative;
  z-index: 3;
  width: 100%;
  height: 100%;
}

.pulse {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(22, 161, 94, 0.18);
}

.pulse.one {
  width: 174rpx;
  height: 174rpx;
}

.pulse.two {
  width: 214rpx;
  height: 214rpx;
}

.title {
  color: #111816;
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 900;
}

.title text {
  color: #07833f;
}

.desc {
  margin: 26rpx auto 0;
  max-width: 610rpx;
  color: #5b6560;
  font-size: 30rpx;
  line-height: 1.72;
  text-align: left;
}

.steps {
  margin-top: 40rpx;
  padding: 24rpx 34rpx;
  text-align: left;
}

.step {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0;
  color: #5b6560;
  font-size: 29rpx;
  border-bottom: 1rpx solid rgba(17, 24, 22, 0.07);
}

.step:last-child {
  border-bottom: 0;
}

.step-dot {
  flex: 0 0 auto;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(17, 24, 22, 0.16);
  color: #6f7874;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.step.done {
  color: #111816;
  font-weight: 700;
}

.step.done .step-dot {
  background: #16a15e;
  border-color: #16a15e;
  color: #ffffff;
}

.phone-note {
  margin: 32rpx 0 36rpx;
  padding: 26rpx 30rpx;
  border-radius: 22rpx;
  background: rgba(22, 161, 94, 0.08);
  color: #168f56;
  font-size: 27rpx;
  line-height: 1.6;
  text-align: left;
}

.later-link {
  margin-top: 30rpx;
  color: #68736e;
  font-size: 29rpx;
  text-align: center;
}
