.call-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #ffffff;
  background: #063b2a;
}

.call-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 18%, rgba(28, 177, 106, 0.28), transparent 26%),
    radial-gradient(circle at 18% 86%, rgba(25, 136, 83, 0.24), transparent 32%),
    linear-gradient(160deg, #084934 0%, #063b2a 54%, #04291f 100%);
}

.call-content {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  padding: 52rpx 44rpx calc(30rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.call-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.round-mini {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 800;
  border: 0;
}

.round-mini::after {
  border: 0;
}

.call-top .round-mini:last-child {
  opacity: 0;
  pointer-events: none;
}

.timer {
  color: rgba(255, 255, 255, 0.92);
  font-size: 32rpx;
  font-weight: 900;
}

.voice-bars {
  height: 44rpx;
  margin-top: 22rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 8rpx;
}

.voice-bars view {
  width: 8rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #29d47a;
}

.voice-bars .mid {
  height: 28rpx;
}

.voice-bars .tall {
  height: 38rpx;
}

.avatar-wrap {
  width: 202rpx;
  height: 202rpx;
  margin: 28rpx auto 0;
  border-radius: 50%;
  overflow: hidden;
  background: #eef8f2;
  box-shadow: 0 28rpx 52rpx rgba(0, 0, 0, 0.18);
}

.call-avatar-img {
  width: 100%;
  height: 100%;
}

.assistant-name {
  margin-top: 30rpx;
  text-align: center;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 900;
}

.assistant-state {
  margin-top: 14rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.78);
  font-size: 30rpx;
}

.dots {
  display: flex;
  justify-content: center;
  gap: 14rpx;
  margin-top: 16rpx;
}

.dots text {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(41, 212, 122, 0.92);
}

.question-card {
  margin-top: 32rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background: #ffffff;
  color: #111816;
  box-shadow: 0 22rpx 52rpx rgba(0, 0, 0, 0.14);
}

.question-label {
  color: #16a15e;
  font-size: 28rpx;
  font-weight: 800;
}

.question-title {
  margin-top: 16rpx;
  color: #111816;
  font-size: 36rpx;
  line-height: 1.42;
  font-weight: 900;
}

.question-desc {
  margin-top: 12rpx;
  color: #8a9490;
  font-size: 29rpx;
}

.option-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.quick-option {
  min-height: 88rpx;
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(17, 24, 22, 0.10);
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #ffffff;
}

.option-icon {
  flex: 0 0 auto;
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: rgba(22, 161, 94, 0.08);
  color: #07833f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.option-label {
  flex: 1;
  color: #111816;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 800;
}

.option-arrow {
  color: #9aa3a0;
  font-size: 34rpx;
}

.ready-button {
  height: 76rpx;
  line-height: 76rpx;
  margin-top: 26rpx;
  border-radius: 16rpx;
  background: #16a15e;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.ready-button::after {
  border: 0;
}

.voice-controls,
.text-controls {
  position: absolute;
  left: 44rpx;
  right: 44rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.call-actions {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.call-action {
  width: 160rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  font-weight: 700;
}

.action-circle {
  width: 122rpx;
  height: 122rpx;
  margin: 0 auto 16rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #111816;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 34rpx rgba(0, 0, 0, 0.18);
}

.action-circle.active {
  color: #16a15e;
}

.action-circle.mic {
  position: relative;
  background: #151a18;
}

.action-circle.mic::before {
  content: "";
  width: 30rpx;
  height: 46rpx;
  border-radius: 18rpx;
  background: #ffffff;
}

.action-circle.mic::after {
  content: "";
  position: absolute;
  bottom: 22rpx;
  width: 42rpx;
  height: 28rpx;
  border-bottom: 6rpx solid #ffffff;
  border-radius: 0 0 30rpx 30rpx;
}

.action-circle.mic.holding {
  background: #16a15e;
}

.action-circle.hang {
  background: #ef3f3a;
  color: #ffffff;
  font-size: 46rpx;
  line-height: 1;
}

.switch-mode {
  margin-top: 24rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 29rpx;
  text-align: center;
}

.text-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
  padding: 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
}

.text-input {
  flex: 1;
  height: 64rpx;
  color: #111816;
  font-size: 28rpx;
}

.send-button {
  width: 112rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 16rpx;
  background: #16a15e;
  color: #ffffff;
  font-weight: 800;
  font-size: 27rpx;
}

.send-button::after {
  border: 0;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  background: rgba(0, 0, 0, 0.58);
}

.mic-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 60;
  padding: 22rpx 40rpx calc(36rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  color: #111816;
  box-shadow: 0 -24rpx 70rpx rgba(0, 0, 0, 0.20);
}

.sheet-handle {
  width: 70rpx;
  height: 8rpx;
  margin: 0 auto 34rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 22, 0.18);
}

.sheet-row {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.sheet-icon {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(22, 161, 94, 0.08);
  color: #07833f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.sheet-title {
  color: #070b09;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 900;
}

.sheet-desc {
  margin-top: 12rpx;
  color: #68736e;
  font-size: 28rpx;
  line-height: 1.6;
}

.sheet-note {
  margin-top: 30rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: rgba(22, 161, 94, 0.06);
  color: #68736e;
  font-size: 26rpx;
  text-align: center;
}

.sheet-button {
  margin-top: 34rpx;
}

.sheet-text-link {
  margin-top: 26rpx;
  color: #07833f;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
}
