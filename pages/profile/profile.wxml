<view class="page profile-page">
  <view class="mini-top">
    <view class="app-name">下笔有元</view>
    <view class="capsule">•••  ○</view>
  </view>

  <view class="user-card card">
    <view class="avatar">
      <image wx:if="{{profile.avatarUrl}}" src="{{profile.avatarUrl}}" mode="aspectFill"></image>
      <text wx:else>王</text>
    </view>
    <view>
      <view class="nickname">{{profile.nickname || '新朋友'}}</view>
      <view class="member">手机号未绑定 · 免费体验用户</view>
    </view>
    <button class="bind-phone">绑定手机号</button>
  </view>

  <view class="benefit-card">
    <view class="medal">✓</view>
    <view>
      <view class="benefit-title">首次免费销售信已领取</view>
      <view class="benefit-desc">开通年卡后，可以继续让智多星帮你写、保存和完善。</view>
    </view>
    <view class="benefit-arrow">〉</view>
  </view>

  <view class="menu card">
    <view class="menu-item" bindtap="goRecords"><text class="menu-icon">▣</text><text>我的销售信</text><text class="arrow">〉</text></view>
    <view class="menu-item" bindtap="goMemory"><text class="menu-icon">●</text><text>我的档案</text><text class="arrow">〉</text></view>
    <view class="menu-item"><text class="menu-icon">▤</text><text>订单记录</text><text class="arrow">〉</text></view>
    <view class="menu-item vip"><text class="menu-icon crown">♛</text><text>升级年卡</text><text class="vip-more">享更多权益</text><text class="arrow">〉</text></view>
    <view class="menu-item"><text class="menu-icon">•••</text><text>帮助反馈</text><text class="arrow">〉</text></view>
    <view class="menu-item"><text class="menu-icon">◎</text><text>设置</text><text class="arrow">〉</text></view>
  </view>

  <view class="nav-shell">
    <view class="nav-item" bindtap="goHome"><view class="nav-icon">⌂</view><view>首页</view></view>
    <view class="nav-item" bindtap="goRecords"><view class="nav-icon">▤</view><view>记录</view></view>
    <view class="nav-item active"><view class="nav-icon">○</view><view>我的</view></view>
  </view>
</view>
