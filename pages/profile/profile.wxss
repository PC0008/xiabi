.profile-page {
  padding-bottom: 148rpx;
  background: #ffffff;
}

.user-card {
  margin-top: 72rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 36rpx;
  border-radius: 28rpx;
}

.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(145deg, #eef3f0, #dfe7e3);
  color: #111816;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 900;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.nickname {
  color: #111816;
  font-size: 40rpx;
  font-weight: 900;
}

.member {
  margin-top: 8rpx;
  color: #7a8580;
  font-size: 27rpx;
}

.bind-phone {
  margin-left: auto;
  width: 160rpx;
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 18rpx;
  border: 1rpx solid #07833f;
  background: #ffffff;
  color: #07833f;
  font-size: 27rpx;
  font-weight: 800;
}

.bind-phone::after {
  border: 0;
}

.benefit-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(22, 161, 94, 0.14);
  background: linear-gradient(120deg, rgba(22, 161, 94, 0.08), rgba(255, 255, 255, 0.96));
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.medal {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #07833f;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 900;
}

.benefit-title {
  color: #111816;
  font-size: 32rpx;
  font-weight: 900;
}

.benefit-desc {
  margin-top: 10rpx;
  color: #66716c;
  font-size: 26rpx;
  line-height: 1.45;
}

.benefit-arrow {
  margin-left: auto;
  color: #07833f;
  font-size: 48rpx;
}

.menu {
  margin-top: 30rpx;
  padding: 0 30rpx;
  border-radius: 28rpx;
}

.menu-item {
  min-height: 98rpx;
  border-bottom: 1rpx solid rgba(17, 24, 22, 0.08);
  color: #111816;
  font-size: 31rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-icon {
  width: 46rpx;
  height: 46rpx;
  border-radius: 12rpx;
  background: rgba(22, 161, 94, 0.10);
  color: #07833f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
}

.menu-icon.crown {
  background: rgba(224, 174, 72, 0.16);
  color: #d29318;
}

.menu-item.vip {
  margin: 18rpx -10rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(224, 174, 72, 0.20);
  background: rgba(224, 174, 72, 0.06);
}

.arrow {
  margin-left: auto;
  color: #8a9490;
  font-size: 38rpx;
}

.vip-more {
  margin-left: auto;
  color: #c88918;
  font-size: 26rpx;
}
