.confirm-page {
  background: #ffffff;
}

.page-tag {
  display: inline-flex;
  margin-top: 58rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(22, 161, 94, 0.10);
  color: #16a15e;
  font-size: 26rpx;
  font-weight: 800;
}

.title {
  margin-top: 34rpx;
  color: #111816;
  font-size: 54rpx;
  line-height: 1.2;
  font-weight: 900;
}

.desc {
  margin-top: 18rpx;
  color: #5b6560;
  font-size: 31rpx;
  line-height: 1.7;
}

.summary {
  margin-top: 42rpx;
  padding: 8rpx 30rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(17, 24, 22, 0.08);
}

.summary-row:last-child {
  border-bottom: 0;
}

.summary-icon {
  flex: 0 0 auto;
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: rgba(22, 161, 94, 0.08);
  color: #07833f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
}

.label {
  color: #111816;
  font-size: 31rpx;
  font-weight: 900;
}

.value {
  margin-top: 10rpx;
  color: #66716c;
  font-size: 27rpx;
  line-height: 1.48;
  font-weight: 700;
}

.edit {
  flex: 0 0 auto;
  color: #16a15e;
  font-size: 29rpx;
  font-weight: 800;
}

.tip-card {
  display: flex;
  gap: 24rpx;
  margin: 32rpx 0 40rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(22, 161, 94, 0.16);
  background: linear-gradient(120deg, rgba(22, 161, 94, 0.07), rgba(255, 255, 255, 0.92));
}

.tip-icon {
  flex: 0 0 auto;
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: rgba(22, 161, 94, 0.08);
  color: #07833f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 900;
}

.tip-main {
  flex: 1;
}

.tip-title {
  color: #168f56;
  font-size: 32rpx;
  font-weight: 900;
}

.tip-text {
  margin-top: 10rpx;
  color: #53605a;
  font-size: 27rpx;
  line-height: 1.65;
}

.tip-link {
  margin-top: 20rpx;
  color: #07833f;
  font-size: 28rpx;
  font-weight: 900;
}

.generate-button {
  margin-top: 8rpx;
}

.back-chat {
  margin-top: 22rpx;
  box-shadow: 0 12rpx 30rpx rgba(18, 33, 26, 0.05);
}
