.letter-page {
  background: #ffffff;
}

.doc-head {
  padding-top: 58rpx;
  padding-bottom: 28rpx;
}

.doc-tag {
  display: inline-flex;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(22, 161, 94, 0.10);
  color: #16a15e;
  font-size: 26rpx;
  font-weight: 800;
}

.title {
  margin-top: 28rpx;
  color: #111816;
  font-size: 50rpx;
  line-height: 1.22;
  font-weight: 900;
}

.meta {
  margin-top: 18rpx;
  color: #7a8580;
  font-size: 27rpx;
}

.letter-card {
  position: relative;
  overflow: hidden;
  padding: 36rpx 34rpx;
  border-radius: 30rpx;
}

.paragraph {
  margin-bottom: 30rpx;
  color: #222b27;
  font-size: 30rpx;
  line-height: 1.9;
}

.paragraph:last-child {
  margin-bottom: 0;
}

.blurred {
  color: rgba(34, 43, 39, 0.22);
}

.lock-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 96rpx 32rpx 34rpx;
  background: linear-gradient(rgba(255,255,255,0), rgba(255,255,255,0.96) 34%, #ffffff);
  text-align: center;
}

.image-suggestion {
  margin-top: 34rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(22, 161, 94, 0.16);
  background: rgba(22, 161, 94, 0.06);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.image-icon {
  flex: 0 0 auto;
  width: 78rpx;
  height: 78rpx;
  border-radius: 16rpx;
  background: rgba(22, 161, 94, 0.10);
  color: #07833f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 900;
}

.suggest-title {
  color: #07833f;
  font-size: 28rpx;
  font-weight: 900;
}

.suggest-desc {
  margin-top: 8rpx;
  color: #68736e;
  font-size: 25rpx;
}

.suggest-arrow {
  margin-left: auto;
  color: #07833f;
  font-size: 42rpx;
}

.lock-title {
  color: #111816;
  font-size: 31rpx;
  font-weight: 900;
}

.lock-desc {
  margin-top: 10rpx;
  color: #68736e;
  font-size: 25rpx;
}

.lock-button {
  margin-top: 22rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.save-button {
  margin-top: 34rpx;
}

.rewrite-link {
  margin-top: 28rpx;
  color: #07833f;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
}
