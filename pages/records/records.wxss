.records-page {
  padding-bottom: 148rpx;
  background: #ffffff;
}

.title {
  margin-top: 68rpx;
  color: #111816;
  font-size: 58rpx;
  font-weight: 900;
}

.tabs {
  display: flex;
  gap: 14rpx;
  margin: 32rpx 0;
  overflow: hidden;
}

.tab {
  padding: 15rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #7a8580;
  font-size: 27rpx;
  font-weight: 700;
}

.tab.active {
  background: rgba(22, 161, 94, 0.10);
  color: #16a15e;
}

.letter-item {
  display: flex;
  gap: 24rpx;
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 26rpx;
}

.doc-thumb {
  flex: 0 0 auto;
  width: 106rpx;
  height: 106rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 900;
}

.doc-thumb.green {
  background: rgba(22, 161, 94, 0.08);
  color: #07833f;
}

.doc-thumb.orange {
  background: rgba(238, 145, 30, 0.12);
  color: #e28717;
}

.item-main {
  flex: 1;
}

.item-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.item-title {
  color: #111816;
  font-size: 31rpx;
  line-height: 1.38;
  font-weight: 900;
}

.status {
  flex: 0 0 auto;
  color: #16a15e;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(22, 161, 94, 0.08);
  font-size: 25rpx;
  font-weight: 800;
}

.status.pending {
  color: #be7a21;
  background: rgba(238, 145, 30, 0.12);
}

.item-meta {
  margin-top: 14rpx;
  color: #7a8580;
  font-size: 24rpx;
}

.item-actions {
  margin-top: 18rpx;
  color: #168f56;
  font-size: 27rpx;
  font-weight: 700;
}

.status-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(22, 161, 94, 0.14);
  background: linear-gradient(120deg, rgba(22, 161, 94, 0.04), rgba(255, 255, 255, 0.95));
}

.status-head {
  display: flex;
  justify-content: space-between;
  color: #07833f;
  font-size: 30rpx;
  font-weight: 900;
}

.status-head text {
  color: #6f7874;
  font-size: 25rpx;
}

.legend-row {
  display: grid;
  grid-template-columns: 22rpx 150rpx 1fr;
  gap: 14rpx;
  align-items: start;
  margin-top: 20rpx;
  color: #6a736f;
  font-size: 25rpx;
  line-height: 1.45;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: 9rpx;
  border-radius: 50%;
}

.dot.blue { background: #3d7dcc; }
.dot.orange { background: #ee8b16; }
.dot.purple { background: #8755c7; }
.dot.green { background: #16a15e; }
