{
  "name": "xiabi",
  "private": true,
  "scripts": {
    "dev": "edgespark dev",
    "build": "npm --prefix web run build",
    "typecheck": "npm --prefix server run typecheck && npm --prefix web run typecheck",
    "check:ui": "node scripts/check-ui-actions.mjs",
    "check:env-contract": "node scripts/check-env-contract.mjs",
    "check:admin-config-control": "node scripts/check-admin-config-control.mjs",
    "check:sensitive-output-safety": "node scripts/check-sensitive-output-safety.mjs",
    "check:sms-code-safety": "node scripts/check-sms-code-safety.mjs",
    "check:admin-permissions": "node scripts/check-admin-permissions.mjs",
    "check:public-session-safety": "node scripts/check-public-session-safety.mjs",
    "check:bind-phone-unique": "node scripts/check-bind-phone-unique.mjs",
    "check:payment-entitlement-safety": "node scripts/check-payment-entitlement-safety.mjs",
    "verify:order-payment-switch": "node scripts/verify-order-payment-switch.mjs",
    "verify:journey": "playwright test scripts/verify-user-journey.spec.mjs --reporter=line",
    "verify:live": "node scripts/verify-live.mjs",
    "verify:production": "node scripts/verify-production.mjs",
    "verify:production:report": "node scripts/verify-production.mjs --report docs/production-readiness-latest.md",
    "verify:preflight": "node scripts/final-preflight.mjs",
    "delivery:status": "node scripts/delivery-status.mjs",
    "deploy:dry": "edgespark deploy --dry-run",
    "deploy": "edgespark deploy",
    "logs": "edgespark log tail"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
