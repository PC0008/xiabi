page {
  min-height: 100vh;
  background: #fbfcfb;
  color: #111816;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

button {
  border-radius: 18rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
  line-height: normal;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 58rpx 40rpx;
}

.primary-button {
  height: 104rpx;
  line-height: 104rpx;
  background: #16a15e;
  color: #ffffff;
  font-weight: 900;
  font-size: 33rpx;
  border: 0;
  border-radius: 26rpx;
  box-shadow: 0 22rpx 42rpx rgba(22, 161, 94, 0.24);
}

.secondary-button {
  height: 92rpx;
  line-height: 92rpx;
  background: #ffffff;
  color: #168f56;
  font-weight: 800;
  font-size: 30rpx;
  border: 1rpx solid rgba(22, 161, 94, 0.18);
  box-shadow: none;
}

.muted {
  color: #7a8580;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.nav-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 126rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(17, 24, 22, 0.08);
}

.nav-item {
  min-width: 120rpx;
  text-align: center;
  color: #7a8580;
  font-size: 24rpx;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto 6rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  color: currentColor;
}

.nav-item.active {
  color: #16a15e;
  font-weight: 700;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  border: 1rpx solid rgba(17, 24, 22, 0.07);
  box-shadow: 0 18rpx 42rpx rgba(18, 33, 26, 0.06);
}

.mini-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.app-name {
  color: #070b09;
  font-size: 36rpx;
  font-weight: 900;
}

.capsule {
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 24, 22, 0.10);
  color: #070b09;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  letter-spacing: 5rpx;
  background: rgba(255, 255, 255, 0.82);
  opacity: 0;
  pointer-events: none;
}
